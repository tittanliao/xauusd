// © Tittan
// Strategy: XAUUSD-Long-S1-AweWithBB-V3.6.2
// Update: Fix lookahead_on → lookahead_off (repaint fix) + EMA trend filter group (arch align with S2A/S2B)
//         Carries forward V3.6.1: BB %B filter + 4H HTF RSI filter
// Entry label: S1BB_LE  Exit labels: S1BB_TP1 / S1BB_TP2 / S1BB_SL / S1BB_TimeWin / S1BB_TimeLoss
//@version=6
strategy(title="XAUUSD-Long-S1-AweWithBB-V3.6.2",
 shorttitle="S1-Awe-V3.6.2",
 overlay = true,
 format=format.price,
 precision=2,
 default_qty_type=strategy.cash, initial_capital=10000,
 default_qty_value=10000, commission_value=0.00,
 slippage=1)

//------------------------------------------------------------------------------
// 1. 前置設定與輸入 (Inputs)
//------------------------------------------------------------------------------
strategy.cancel_all()
MP = strategy.position_size > 0 ? 1 : strategy.position_size < 0 ? -1 : 0

// --- 期貨對應設定 ---
grp_fut = "=== 期貨對應 (Futures Mapping) ==="
show_futures = input.bool(true, "顯示 GC1! 對應價格", group=grp_fut)
futures_sym = input.symbol("COMEX:GC1!", "期貨代碼", group=grp_fut)

// --- 風險管理 ---
grp_risk = "=== 風險與出場 (Risk & Exit) ==="
SL_Pct = input.float(0.5, title="固定止損 % (Fixed SL)", step=0.1, group=grp_risk)
Profit_Ratio_1 = input.float(1.0, title="TP1 盈虧比 (Ratio)", step=0.1, group=grp_risk)
Profit_Ratio_2 = input.float(3.5, title="TP2 盈虧比 (Ratio)", step=0.1, group=grp_risk)
out_k_count = input.int(48, "時間出場 (K棒數)", group=grp_risk)

// --- 技術指標參數 ---
grp_ind = "=== S1 核心指標參數 ==="
bb_length = input.int(20, minval=1, title="BB Length", group=grp_ind)
bb_mult   = input.float(2.0, title="BB Multiplier", minval=0.5, maxval=10, group=grp_ind)
bb_source = input(close, title="BB Source", group=grp_ind)
fast_ma_len = input.int(3, title="Fast EMA Length", minval=2, group=grp_ind)
ao_slow_len = input.int(34, minval=1, title="AO Slow Length", group=grp_ind)
ao_fast_len = input.int(5, minval=1, title="AO Fast Length", group=grp_ind)

// --- 過濾器設定 (1H MA) ---
grp_filter = "=== 過濾器設定 ==="
use_ma1h_filter = input.bool(true, title="啟用 1H MA 過濾器", group=grp_filter)
ma1h_length = input.int(3, minval=1, title="1H MA Length", group=grp_filter)

// --- 趨勢 EMA 過濾器 (V3.6.2 新增，與 S2A/S2B 架構統一) ---
grp_trend = "=== 趨勢 EMA 過濾器 ==="
use_trend_filter = input.bool(false, "啟用趨勢 EMA 過濾器",
 group=grp_trend,
 tooltip="關閉 = 原始邏輯\n打開 = close 需高於指定時框的 EMA，確認在上升結構中才進場\n與 S2A/S2B 同樣的架構設計")
trend_tf  = input.string("240", "趨勢 EMA 時框", options=["60", "240"], group=grp_trend,
 tooltip="建議 4H(240)，確認大方向為多頭")
trend_len = input.int(200, "趨勢 EMA 週期", minval=50, group=grp_trend)

// --- 洞察濾網 (Insight Filters) ---
grp_insight = "=== 洞察濾網 (Insight Filters) ==="
use_insight = input.bool(false, "啟用洞察濾網",
 group=grp_insight,
 tooltip="關閉 = 原始邏輯\n打開 = 加入 DXY RSI 日線 + RSI 動能確認\n目的：減少 immediate_loss（進場即虧）比例")
dxy_rsi_thresh = input.int(50, "DXY RSI 日線門檻 (< 此值才進場)",
 minval=20, maxval=80, group=grp_insight,
 tooltip="DXY RSI < 30 超賣時三策略勝率均最高 (60.9%)\nDXY RSI < 50 可過濾掉美元強勢期")
rsi_len_insight = input.int(14, "RSI 週期 (動能確認用)", minval=5, group=grp_insight,
 tooltip="進場 K 棒的 RSI 需高於前一根，確認動能仍在上升中")

// --- BB 位置過濾器 ---
grp_bb_pos = "=== BB 位置過濾器 ==="
use_bb_filter = input.bool(false, "啟用 BB 位置過濾器",
 group=grp_bb_pos,
 tooltip="關閉 = 原始邏輯\n打開 = 只在 BB %B ≥ 門檻時進場\n分析結果：above_upper 勝率 77.8% vs 基準 53.2%")
bb_pct_b_min = input.float(0.6, "BB %B 最低門檻",
 minval=0.0, maxval=2.0, step=0.05,
 group=grp_bb_pos,
 tooltip="%B = (close - lower) / (upper - lower)\n0.5 = 中軌  |  1.0 = 上軌  |  >1.0 = 突破上軌\n建議值：0.6 或 1.0")

// --- 4H HTF RSI 過濾器 ---
grp_htf = "=== 4H HTF RSI 過濾器 ==="
use_htf_filter = input.bool(false, "啟用 4H HTF 過濾器",
 group=grp_htf,
 tooltip="關閉 = 原始邏輯\n打開 = 跳過 4H RSI 看空狀態（RSI < RSI-MA 且斜率負）\nMTF 分析：4H bearish 勝率 47.9% vs bullish 64.0%")
htf_rsi_len = input.int(14, "4H RSI 週期", minval=5, group=grp_htf)
htf_rsi_ma_len = input.int(14, "4H RSI-MA 週期", minval=3, group=grp_htf)

// --- 統計面板 ---
grp_stat = "=== 統計面板設定 ==="
show_table = input.bool(false, title="顯示統計表格", group=grp_stat)
show_detail_stats = input.bool(true, title="顯示詳細時段統計", group=grp_stat)

//------------------------------------------------------------------------------
// 2. 指標運算 (Indicators)
//------------------------------------------------------------------------------
// BB
bb_basis = ta.sma(bb_source, bb_length)
bb_dev   = ta.stdev(bb_source, bb_length) * bb_mult
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
bb_pct_b = (bb_dev > 0) ? (close - bb_lower) / (bb_upper - bb_lower) : 0.5

// Fast MA & AO
fast_ma = ta.ema(bb_source, fast_ma_len)
xSMA1_hl2 = ta.sma(hl2, ao_fast_len)
xSMA2_hl2 = ta.sma(hl2, ao_slow_len)
AO_Val = xSMA1_hl2 - xSMA2_hl2
AO_State = AO_Val >= 0 ? (AO_Val > AO_Val[1] ? 1 : 2) : (AO_Val > AO_Val[1] ? -1 : -2)

// 1H MA Filter — lookahead_off 修正（V3.6.2 bugfix，原 lookahead_on 會重繪）
ma1h = request.security(syminfo.tickerid, "60", ta.sma(close, ma1h_length), lookahead=barmerge.lookahead_off)

// 趨勢 EMA（HTF）
trend_ema = request.security(syminfo.tickerid, trend_tf, ta.ema(close, trend_len), lookahead=barmerge.lookahead_off)

// 期貨價差
fut_close = request.security(futures_sym, timeframe.period, close)
basis_spread = fut_close - close

// 洞察濾網：DXY RSI 日線
dxy_rsi_d = request.security("TVC:DXY", "D", ta.rsi(close, 14), lookahead=barmerge.lookahead_off)

// 洞察濾網：RSI 動能
rsi_curr = ta.rsi(close, rsi_len_insight)
rsi_momentum_ok = rsi_curr > rsi_curr[1]

// 4H HTF RSI 狀態
htf_rsi_val     = request.security(syminfo.tickerid, "240", ta.rsi(close, htf_rsi_len), lookahead=barmerge.lookahead_off)
htf_rsi_ma      = request.security(syminfo.tickerid, "240", ta.sma(ta.rsi(close, htf_rsi_len), htf_rsi_ma_len), lookahead=barmerge.lookahead_off)
htf_rsi_ma_prev = request.security(syminfo.tickerid, "240", ta.sma(ta.rsi(close, htf_rsi_len), htf_rsi_ma_len)[1], lookahead=barmerge.lookahead_off)
htf_is_bearish  = htf_rsi_val < htf_rsi_ma and htf_rsi_ma < htf_rsi_ma_prev

// 過濾條件
filter_1h_ok  = not use_ma1h_filter  or close > ma1h
trend_ok      = not use_trend_filter or close > trend_ema
insight_ok    = not use_insight      or (dxy_rsi_d < dxy_rsi_thresh and rsi_momentum_ok)
bb_pos_ok     = not use_bb_filter    or (bb_pct_b >= bb_pct_b_min)
htf_ok        = not use_htf_filter   or not htf_is_bearish

//------------------------------------------------------------------------------
// 3. 進場邏輯 (Entry Logic)
//------------------------------------------------------------------------------
MaxUseBars = 1 + math.max(bb_length, 1)
var LongEntry = false

LongCondition = ta.crossover(fast_ma, bb_basis) and (close > bb_basis) and (math.abs(AO_State) == 1) and filter_1h_ok and trend_ok and insight_ok and bb_pos_ok and htf_ok

LongEntry := bar_index > MaxUseBars and MP == 0 and LongCondition

if LongEntry
    strategy.entry("S1BB_LE", strategy.long, comment="S1BB_LE")

//------------------------------------------------------------------------------
// 4. 出場邏輯 (Profit Flyer)
//------------------------------------------------------------------------------
EntryPrice     = strategy.opentrades.entry_price(strategy.opentrades - 1)
BarsSinceEntry = bar_index - strategy.opentrades.entry_bar_index(strategy.opentrades - 1)

SLPrice  = EntryPrice * (1 - SL_Pct / 100)
PTPrice1 = EntryPrice * (1 + (SL_Pct / 100 * Profit_Ratio_1))
PTPrice2 = EntryPrice * (1 + (SL_Pct / 100 * Profit_Ratio_2))

var float exit_stop_price = na

if MP > 0
    if close >= PTPrice2
        exit_stop_price := math.max(PTPrice2, ta.lowest(low, out_k_count/4))
        strategy.exit("S1BB_TP2", from_entry="S1BB_LE", stop=exit_stop_price, comment="S1BB_TP2")
    else if close >= PTPrice1
        exit_stop_price := math.max(PTPrice1, ta.lowest(low, out_k_count/2))
        strategy.exit("S1BB_TP1", from_entry="S1BB_LE", stop=exit_stop_price, comment="S1BB_TP1")
    else
        strategy.exit("S1BB_SL", from_entry="S1BB_LE", stop=SLPrice, comment_loss="S1BB_SL")

    if BarsSinceEntry >= out_k_count
        if strategy.openprofit >= 0
            exit_stop_price := math.max(SLPrice, ta.lowest(low, out_k_count))
            strategy.exit("S1BB_TimeWin", from_entry="S1BB_LE", stop=exit_stop_price, comment="S1BB_TimeWin")
        else
            exit_stop_price := low
            strategy.exit("S1BB_TimeLoss", from_entry="S1BB_LE", stop=exit_stop_price, comment="S1BB_TimeLoss")

alertcondition(LongEntry, title="S1BB Entry", message="S1BB Breakout Buy, Price={{close}}")

//------------------------------------------------------------------------------
// 5. 視覺化 (Visualization)
//------------------------------------------------------------------------------
plot(bb_basis, title="Basis", color=color.new(color.red, 0), linewidth=2)
p1 = plot(bb_upper, title="Upper", color=color.new(color.blue, 0))
p2 = plot(bb_lower, title="Lower", color=color.new(color.blue, 0))
fill(p1, p2, color=color.new(color.silver, 90))
plot(fast_ma, title="Fast EMA", color=color.new(color.black, 0))
plot(use_trend_filter ? trend_ema : na, title="Trend EMA", color=color.new(color.purple, 0), linewidth=1)

bgcolor(use_insight    and dxy_rsi_d < dxy_rsi_thresh ? color.new(color.green, 95) : na, title="DXY Favorable")
bgcolor(use_htf_filter and htf_is_bearish             ? color.new(color.red,   93) : na, title="4H Bearish Warning")

// 被過濾掉的訊號（灰色）
raw_signal = ta.crossover(fast_ma, bb_basis) and (close > bb_basis) and (math.abs(AO_State) == 1) and filter_1h_ok
plotshape(raw_signal and not LongEntry, title="Filtered Signal",
 location=location.belowbar, color=color.new(color.gray, 60),
 style=shape.triangleup, size=size.tiny, text="x")

if strategy.opentrades > 0 and strategy.opentrades.entry_bar_index(0) == bar_index
    yPos = high * 1.002
    txt_spot = "Spot (XAUUSD)\nLE: "   + str.tostring(EntryPrice, "#.##") +
               "\nSL: "  + str.tostring(SLPrice,   "#.##") +
               "\nTP1: " + str.tostring(PTPrice1,  "#.##") +
               "\nTP2: " + str.tostring(PTPrice2,  "#.##")
    txt_filters = ""
    if use_insight
        txt_filters += "\n[Insight] DXY:" + str.tostring(dxy_rsi_d, "#.#") +
                       " Mom:" + (rsi_momentum_ok ? "✓" : "✗")
    if use_bb_filter
        txt_filters += "\n[BB %B] " + str.tostring(bb_pct_b, "#.##") +
                       (bb_pos_ok ? " ✓" : " ✗")
    if use_htf_filter
        txt_filters += "\n[4H] " + (htf_is_bearish ? "✗ bearish" : "✓ ok")
    if use_trend_filter
        txt_filters += "\n[EMA" + str.tostring(trend_len) + "] " +
                       (close > trend_ema ? "✓" : "✗")
    txt_fut = ""
    if show_futures
        txt_fut := "\n\nGC1!\nLE: "   + str.tostring(EntryPrice + basis_spread, "#.##") +
                   "\nSL: "  + str.tostring(SLPrice   + basis_spread, "#.##") +
                   "\nTP1: " + str.tostring(PTPrice1  + basis_spread, "#.##") +
                   "\nTP2: " + str.tostring(PTPrice2  + basis_spread, "#.##") +
                   "\n(Basis: " + str.tostring(basis_spread, "#.##") + ")"
    label.new(bar_index, yPos, text=txt_spot + txt_filters + txt_fut,
     style=label.style_label_down, color=color.new(color.teal, 0),
     textcolor=color.white, size=size.small)

//------------------------------------------------------------------------------
// 6. 統計表格 (Stats)
//------------------------------------------------------------------------------
var wins_total = array.new_int(5, 0), var losses_total = array.new_int(5, 0)
var wins_asia  = array.new_int(5, 0), var losses_asia  = array.new_int(5, 0)
var wins_euro  = array.new_int(5, 0), var losses_euro  = array.new_int(5, 0)
var wins_us    = array.new_int(5, 0), var losses_us    = array.new_int(5, 0)
var entryWeekdays = array.new_int(), var entrySessions = array.new_int(), var entryPrices = array.new_float()

t_us   = time(timeframe.period, "2030-0500", "Asia/Taipei")
t_euro = time(timeframe.period, "1500-2030", "Asia/Taipei")

if strategy.position_size[1] == 0 and strategy.position_size > 0
    wd = dayofweek(time, "Asia/Taipei")
    array.push(entryWeekdays, wd)
    array.push(entryPrices, strategy.position_avg_price)
    sess_id = 0
    if not na(t_us)
        sess_id := 2
    else if not na(t_euro)
        sess_id := 1
    array.push(entrySessions, sess_id)

if strategy.position_size[1] > 0 and strategy.position_size == 0 and array.size(entryWeekdays) > 0
    wd = array.shift(entryWeekdays)
    sess = array.shift(entrySessions)
    ep = array.shift(entryPrices)
    profitValue = close - ep
    idx = wd - 2
    if idx >= 0 and idx < 5
        is_win = profitValue > 0
        if is_win
            array.set(wins_total, idx, array.get(wins_total, idx) + 1)
        else
            array.set(losses_total, idx, array.get(losses_total, idx) + 1)
        if sess == 0
            if is_win
                array.set(wins_asia, idx, array.get(wins_asia, idx) + 1)
            else
                array.set(losses_asia, idx, array.get(losses_asia, idx) + 1)
        else if sess == 1
            if is_win
                array.set(wins_euro, idx, array.get(wins_euro, idx) + 1)
            else
                array.set(losses_euro, idx, array.get(losses_euro, idx) + 1)
        else if sess == 2
            if is_win
                array.set(wins_us, idx, array.get(wins_us, idx) + 1)
            else
                array.set(losses_us, idx, array.get(losses_us, idx) + 1)

var table stats = table.new(position.bottom_right, show_detail_stats ? 5 : 2, 6, border_width=1, frame_color=color.black, frame_width=1)
f_txt(w, l) =>
    tot  = w + l
    rate = tot > 0 ? w * 100.0 / tot : na
    str.tostring(w) + "/" + str.tostring(l) + "\n" + (na(rate) ? "-" : str.tostring(rate, "#") + "%")

if show_table
    bg_head  = color.gray
    txt_head = color.white
    table.cell(stats, 0, 0, "Weekday", text_color=txt_head, bgcolor=bg_head)
    if show_detail_stats
        table.cell(stats, 1, 0, "Asia",  text_color=txt_head, bgcolor=bg_head)
        table.cell(stats, 2, 0, "Euro",  text_color=txt_head, bgcolor=bg_head)
        table.cell(stats, 3, 0, "US",    text_color=txt_head, bgcolor=bg_head)
        table.cell(stats, 4, 0, "Total", text_color=txt_head, bgcolor=bg_head)
    else
        table.cell(stats, 1, 0, "Win/Loss (Rate)", text_color=txt_head, bgcolor=bg_head)
    for i = 0 to 4
        wa = array.get(wins_asia,  i), la = array.get(losses_asia,  i)
        we = array.get(wins_euro,  i), le = array.get(losses_euro,  i)
        wu = array.get(wins_us,    i), lu = array.get(losses_us,    i)
        wt = array.get(wins_total, i), lt = array.get(losses_total, i)
        dayLabel = i==0?"Mon":i==1?"Tue":i==2?"Wed":i==3?"Thu":"Fri"
        table.cell(stats, 0, i + 1, dayLabel, text_color=color.black, bgcolor=color.new(color.gray, 90))
        if show_detail_stats
            table.cell(stats, 1, i + 1, f_txt(wa, la), text_color=color.black, bgcolor=color.new(color.gray, 95))
            table.cell(stats, 2, i + 1, f_txt(we, le), text_color=color.black, bgcolor=color.new(color.gray, 95))
            table.cell(stats, 3, i + 1, f_txt(wu, lu), text_color=color.black, bgcolor=color.new(color.gray, 95))
            table.cell(stats, 4, i + 1, f_txt(wt, lt), text_color=color.black, bgcolor=color.new(color.gray, 90))
        else
            table.cell(stats, 1, i + 1, f_txt(wt, lt), text_color=color.black, bgcolor=color.new(color.gray, 90))
