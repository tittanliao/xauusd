// © Tittan
// Strategy: XAUUSD-Long-S2-Hybrid-V2.0
// Description: Hybrid S2 Strategy featuring selectable modes:
// 1. Oversold Reversion (V4.0 Logic) - Fast, V-shape
// 2. Strict Divergence (V1.0 Logic) - Structural, W-shape
// Developed by AI Assistant for XAUUSD Systematic Trading Team
//@version=6
strategy(title="XAUUSD-Long-S2-Hybrid-V2.0",
 shorttitle="S2-Hybrid-V2.0",
 overlay = true,
 format=format.price,
 precision=2, 
 default_qty_type=strategy.cash, initial_capital=10000, 
 default_qty_value=10000, commission_value=0.00, 
 slippage=1) 

//------------------------------------------------------------------------------
// 1. 前置設定與輸入 (Inputs)
//------------------------------------------------------------------------------
strategy.cancel_all()
MP = strategy.position_size > 0 ? 1 : strategy.position_size < 0 ? -1 : 0

// --- 核心邏輯選擇 (New Feature) ---
grp_core = "=== S2 核心: 進場模式 (Entry Mode) ==="
entry_mode = input.string("Oversold Reversion (V-Shape)", "選擇進場模式", 
 options=["Oversold Reversion (V-Shape)", "Strict Divergence (W-Bottom)"], 
 group=grp_core, tooltip="V-Shape: RSI上穿數值即進場 (V4.0風格)\nW-Bottom: 等待RSI墊高背離才進場 (V1.0風格)")

rsi_len = input.int(14, "RSI Length", minval=1, group=grp_core)
rsi_limit = input.int(30, "RSI Threshold (Trigger/Filter)", minval=10, maxval=50, group=grp_core, tooltip="Reversion模式: 穿越此線進場\nDivergence模式: 低點需低於此線")

// --- 背離專用參數 (僅在 W-Bottom 模式有效) ---
grp_div = "=== 背離細部設定 (Divergence Only) ==="
lb_left = input.int(5, "Pivot Left", minval=1, group=grp_div)
lb_right = input.int(2, "Pivot Right", minval=1, group=grp_div)
div_max_range = input.int(60, "Max Range", minval=5, group=grp_div)

// --- 期貨對應設定 (保留) ---
grp_fut = "=== 期貨對應 (Futures Mapping) ==="
show_futures = input.bool(true, "顯示 GC1! 對應價格", group=grp_fut)
futures_sym = input.symbol("COMEX:GC1!", "期貨代碼", group=grp_fut)

// --- 風險管理 (保留) ---
grp_risk = "=== 風險與出場 (Risk & Exit) ==="
sl_fix_pct = input.float(1.0, title="固定止損 % (Fixed SL)", step=0.1, group=grp_risk)
Profit_Ratio_1 = input.float(2.0, title="TP1 盈虧比 (Ratio)", step=0.1, group=grp_risk)
Profit_Ratio_2 = input.float(4.0, title="TP2 盈虧比 (Ratio)", step=0.1, group=grp_risk)
out_k_count = input.int(48, "時間出場 (K棒數)", group=grp_risk)

// --- 統計面板 (保留) ---
grp_stat = "=== 統計面板設定 ==="
show_table = input.bool(false, title="顯示統計表格", group=grp_stat)
show_detail_stats = input.bool(true, title="顯示詳細時段統計", group=grp_stat)

//------------------------------------------------------------------------------
// 2. 指標運算 (Indicators)
//------------------------------------------------------------------------------
// RSI 計算
rsi_val = ta.rsi(close, rsi_len)

// ---------------------------
// 邏輯 A: Oversold Reversion (V4.0 Style)
// ---------------------------
// 簡單粗暴：RSI 從下方穿越閾值
is_reversion = ta.crossover(rsi_val, rsi_limit)

// ---------------------------
// 邏輯 B: Strict Divergence (V1.0 Style)
// ---------------------------
pl_rsi = ta.pivotlow(rsi_val, lb_left, lb_right)
var float prev_rsi_low = na
var float prev_price_low = na
var int prev_bar_index = 0
bool is_bullish_div = false

if not na(pl_rsi)
    curr_price_low = low[lb_right]
    curr_rsi_low = rsi_val[lb_right]
    
    // 條件: 範圍內 + 價格破低 + RSI墊高 + RSI在低檔區
    if (bar_index - prev_bar_index <= div_max_range) and 
       (curr_price_low < prev_price_low) and 
       (curr_rsi_low > prev_rsi_low) and 
       (curr_rsi_low < rsi_limit) // 復用 rsi_limit 作為過濾
        is_bullish_div := true
    
    prev_rsi_low := curr_rsi_low
    prev_price_low := curr_price_low
    prev_bar_index := bar_index[lb_right]

// 期貨價差計算
fut_close = request.security(futures_sym, timeframe.period, close)
basis_spread = fut_close - close

//------------------------------------------------------------------------------
// 3. 進場邏輯 (Entry Logic Switch)
//------------------------------------------------------------------------------
MaxUseBars = 50
var LongEntry = false
bool final_trigger = false

// 模式切換器
if entry_mode == "Oversold Reversion (V-Shape)"
    final_trigger := is_reversion
else
    final_trigger := is_bullish_div

LongEntry := bar_index > MaxUseBars and MP == 0 and final_trigger

if LongEntry
    strategy.entry("S2_Hybrid", strategy.long, comment= entry_mode == "Oversold Reversion (V-Shape)" ? "S2_Rev" : "S2_Div")

//------------------------------------------------------------------------------
// 4. 出場邏輯 (Profit Flyer - Standard)
//------------------------------------------------------------------------------
EntryPrice = strategy.opentrades.entry_price(strategy.opentrades - 1)
BarsSinceEntry = bar_index - strategy.opentrades.entry_bar_index(strategy.opentrades - 1)

SLPrice = EntryPrice * (1 - sl_fix_pct / 100)
PTPrice1 = EntryPrice * (1 + (sl_fix_pct / 100 * Profit_Ratio_1))
PTPrice2 = EntryPrice * (1 + (sl_fix_pct / 100 * Profit_Ratio_2))

var float exit_stop_price = na

if MP > 0
    if close >= PTPrice2
        exit_stop_price := math.max(PTPrice2, ta.lowest(low, out_k_count/4))
        strategy.exit("TP2", from_entry="S2_Hybrid", stop=exit_stop_price, comment="LX_TP2")
    else if close >= PTPrice1
        exit_stop_price := math.max(PTPrice1, ta.lowest(low, out_k_count/2))
        strategy.exit("TP1", from_entry="S2_Hybrid", stop=exit_stop_price, comment="LX_TP1")
    else
        strategy.exit("SL", from_entry="S2_Hybrid", stop=SLPrice, comment_loss="LX_SL")
    
    if BarsSinceEntry >= out_k_count
        if strategy.openprofit >= 0
            exit_stop_price := math.max(SLPrice, ta.lowest(low, out_k_count))
            strategy.exit("TimeWin", from_entry="S2_Hybrid", stop=exit_stop_price, comment="LX_TimeWin")
        else
            exit_stop_price := low
            strategy.exit("TimeLoss", from_entry="S2_Hybrid", stop=exit_stop_price, comment="LX_TimeLoss")

// Alert
alertcondition(LongEntry, title="S2 Hybrid Entry", message="S2 Signal Triggered")

//------------------------------------------------------------------------------
// 5. 視覺化 (Visualization)
//------------------------------------------------------------------------------
// 根據模式顯示不同顏色
plot_col = entry_mode == "Oversold Reversion (V-Shape)" ? color.orange : color.blue
plotshape(LongEntry, title="Entry Signal", location=location.belowbar, color=plot_col, style=shape.triangleup, size=size.small, text="UP")

// Label Info
if strategy.opentrades > 0 and strategy.opentrades.entry_bar_index(0) == bar_index
    yPos = high * 1.003
    txt_spot = "S2 Hybrid (" + (entry_mode == "Oversold Reversion (V-Shape)" ? "Rev" : "Div") + ")\n" +
               "LE: " + str.tostring(EntryPrice, "#.##") + 
               "\nSL: " + str.tostring(SLPrice, "#.##")
    
    txt_fut = ""
    if show_futures
        txt_fut := "\n\nGC1!: " + str.tostring(EntryPrice + basis_spread, "#.##")

    label.new(bar_index, yPos, text=txt_spot + txt_fut, style=label.style_label_down, color=plot_col, textcolor=color.white, size=size.small)

//------------------------------------------------------------------------------
// 6. 統計表格 (Stats) - Standard
//------------------------------------------------------------------------------
var wins_total = array.new_int(5, 0), var losses_total = array.new_int(5, 0)
var wins_asia = array.new_int(5, 0), var losses_asia = array.new_int(5, 0)
var wins_euro = array.new_int(5, 0), var losses_euro = array.new_int(5, 0)
var wins_us   = array.new_int(5, 0), var losses_us   = array.new_int(5, 0)
var entryWeekdays = array.new_int(), var entrySessions = array.new_int(), var entryPrices = array.new_float()

t_us = time(timeframe.period, "2030-0500", "Asia/Taipei")
t_euro = time(timeframe.period, "1500-2030", "Asia/Taipei")

if strategy.position_size[1] == 0 and strategy.position_size > 0
    wd = dayofweek(time, "Asia/Taipei")
    array.push(entryWeekdays, wd)
    array.push(entryPrices, strategy.position_avg_price)
    sess_id = 0 
    if not na(t_us)
        sess_id := 2 
    else if not na(t_euro)
        sess_id := 1 
    array.push(entrySessions, sess_id)

if strategy.position_size[1] > 0 and strategy.position_size == 0 and array.size(entryWeekdays) > 0
    wd = array.shift(entryWeekdays)
    sess = array.shift(entrySessions)
    ep = array.shift(entryPrices)
    profitValue = close - ep
    idx = wd - 2 
    if idx >= 0 and idx < 5
        is_win = profitValue > 0
        if is_win
            array.set(wins_total, idx, array.get(wins_total, idx) + 1)
        else
            array.set(losses_total, idx, array.get(losses_total, idx) + 1)
        if sess == 0 
            if is_win
                array.set(wins_asia, idx, array.get(wins_asia, idx) + 1)
            else
                array.set(losses_asia, idx, array.get(losses_asia, idx) + 1)
        else if sess == 1 
            if is_win
                array.set(wins_euro, idx, array.get(wins_euro, idx) + 1)
            else
                array.set(losses_euro, idx, array.get(losses_euro, idx) + 1)
        else if sess == 2 
            if is_win
                array.set(wins_us, idx, array.get(wins_us, idx) + 1)
            else
                array.set(losses_us, idx, array.get(losses_us, idx) + 1)

var table stats = table.new(position.bottom_right, show_detail_stats ? 5 : 2, 6, border_width=1, frame_color=color.black, frame_width=1)
f_txt(w, l) => 
    tot = w + l
    rate = tot > 0 ? w * 100.0 / tot : na
    str.tostring(w) + "/" + str.tostring(l) + "\n" + (na(rate) ? "-" : str.tostring(rate, "#") + "%")

if show_table
    bg_head = color.gray
    txt_head = color.white
    table.cell(stats, 0, 0, "Weekday", text_color=txt_head, bgcolor=bg_head)
    if show_detail_stats
        table.cell(stats, 1, 0, "Asia", text_color=txt_head, bgcolor=bg_head)
        table.cell(stats, 2, 0, "Euro", text_color=txt_head, bgcolor=bg_head)
        table.cell(stats, 3, 0, "US", text_color=txt_head, bgcolor=bg_head)
        table.cell(stats, 4, 0, "Total", text_color=txt_head, bgcolor=bg_head)
    else
        table.cell(stats, 1, 0, "Win/Loss (Rate)", text_color=txt_head, bgcolor=bg_head)
    for i = 0 to 4
        wa = array.get(wins_asia, i), la = array.get(losses_asia, i)
        we = array.get(wins_euro, i), le = array.get(losses_euro, i)
        wu = array.get(wins_us, i),   lu = array.get(losses_us, i)
        wt = array.get(wins_total, i), lt = array.get(losses_total, i)
        dayLabel = i==0?"Mon":i==1?"Tue":i==2?"Wed":i==3?"Thu":"Fri"
        table.cell(stats, 0, i + 1, dayLabel, text_color=color.black, bgcolor=color.new(color.gray, 90))
        if show_detail_stats
            table.cell(stats, 1, i + 1, f_txt(wa, la), text_color=color.black, bgcolor=color.new(color.gray, 95))
            table.cell(stats, 2, i + 1, f_txt(we, le), text_color=color.black, bgcolor=color.new(color.gray, 95))
            table.cell(stats, 3, i + 1, f_txt(wu, lu), text_color=color.black, bgcolor=color.new(color.gray, 95))
            table.cell(stats, 4, i + 1, f_txt(wt, lt), text_color=color.black, bgcolor=color.new(color.gray, 90))
        else
            table.cell(stats, 1, i + 1, f_txt(wt, lt), text_color=color.black, bgcolor=color.new(color.gray, 90))